generator client {
	provider = "prisma-client-js"
	output = "../src/generated/prisma"
}

datasource db {
	provider = "postgresql"
}

enum JobType {
	FULL_TIME
	PART_TIME
	INTERNSHIP
	CONTRACT
	FREELANCE
}

enum ApplicationStatus {
	APPLIED
	INTERVIEWING
	OFFER
	REJECTED
}

model Application {
	id Int @id @default(autoincrement())
	company_name String
	job_title String
	job_type JobType
	status ApplicationStatus @default(APPLIED)
	applied_date DateTime
	notes String?
	created_at DateTime @default(now())
	updated_at DateTime @updatedAt

	@@map("applications")
}




